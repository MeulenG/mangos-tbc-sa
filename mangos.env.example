# mangos.env — copy to /opt/mangos/etc/mangos.env, fill in, chmod 600, DO NOT COMMIT
# Both seed-db.sh and deploy.sh source this file.

# --- Layout (adjust only if your tree differs) ---
MANGOS_HOME="/opt/mangos"
SRC_DIR="${MANGOS_HOME}/src"            # your fork of mangos-tbc (the core)
TBCDB_DIR="${MANGOS_HOME}/tbc-db"       # cmangos/tbc-db checkout (upstream world DB)
RELEASES_DIR="${MANGOS_HOME}/releases"  # versioned build output
CURRENT_LINK="${MANGOS_HOME}/current"   # symlink -> active release
DATA_DIR="${MANGOS_HOME}/data"          # dbc/maps/vmaps/mmaps (extracted once, shared)
ETC_DIR="${MANGOS_HOME}/etc"            # mangosd.conf / realmd.conf (secrets, not in git)
BACKUP_DIR="${MANGOS_HOME}/backups"

# Your captured migrations, relative to SRC_DIR (e.g. the spell_template file lives here).
# Applied in filename sort order AFTER upstream tbc-db updates.
CUSTOM_SQL_DIR="${SRC_DIR}/sql/updates"

# --- Database ---
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_USER="mangos"
DB_PASS="CHANGE_ME"
DB_WORLD="tbcmangos"       # world DB (creatures/quests/loot/spell_template)
DB_CHARS="tbccharacters"   # player data  — NEVER re-seeded after go-live
DB_REALMD="tbcrealmd"      # accounts/realmlist — NEVER re-seeded after go-live

# --- Build ---
BUILD_JOBS="$(nproc)"
CMAKE_EXTRA="-DBUILD_PLAYERBOTS=ON -DPCH=1 -DCMAKE_BUILD_TYPE=Release"

# --- Services (systemd unit names) ---
SVC_WORLD="mangos-world"
SVC_REALMD="mangos-realmd"

# How many old releases to keep when pruning
KEEP_RELEASES=3
